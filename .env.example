# Backend Configuration
NODE_ENV=production
PORT=5000
JWT_SECRET=your-super-secret-key-change-this-in-production
CLIENT_ORIGIN=https://your-frontend-domain.com
REQUIRE_HTTPS=true

# AI keys must be configured in the hosting provider secret manager.
# Do not commit real keys to git.
GOOGLE_API_KEY=

# Google OAuth Login
# Add this exact redirect URI to your Google OAuth client:
# http://localhost:5050/signin.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5050/signin.com
FRONTEND_URL=http://localhost:5050

# Frontend Configuration (set this in the frontend hosting service)
VITE_API_BASE_URL=https://your-backend-service.onrender.com

# Database Configuration
# Options: sqlite, postgres, mysql
DB_TYPE=sqlite

# For SQLite (default)
# Local default: server/hotel.db
# Production with persistent disk, for example Render:
# DB_PATH=/var/data/hotel.db

# For PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hotel_management
# DB_USER=postgres
# DB_PASSWORD=password

# For MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=hotel_management
# DB_USER=root
# DB_PASSWORD=password
