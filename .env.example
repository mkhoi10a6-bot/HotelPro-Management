# Backend Configuration
PORT=4000
JWT_SECRET=your-super-secret-key-change-this-in-production

# Database Configuration
# Options: sqlite, postgres, mysql
DB_TYPE=sqlite

# For SQLite (default)
# No additional config needed, uses hotel.db file

# For PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hotel_management
# DB_USER=postgres
# DB_PASSWORD=password

# For MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=hotel_management
# DB_USER=root
# DB_PASSWORD=password
